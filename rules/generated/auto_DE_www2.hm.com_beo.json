{
    "name": "auto_DE_www2.hm.com_beo",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://www2.hm.com/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?www2\\.hm\\.com/"
    },
    "prehideSelectors": ["dialog.cookie-consent-popup"],
    "detectCmp": [
        {
            "exists": "dialog.cookie-consent-popup"
        }
    ],
    "detectPopup": [
        {
            "visible": "dialog.cookie-consent-popup"
        }
    ],
    "optIn": [
        {
            "waitForThenClick": "#banner-accept-btn"
        }
    ],
    "optOut": [
        {
            "if": { "exists": "#banner-reject-btn" },
            "then": [{ "waitForThenClick": "#banner-reject-btn" }],
            "else": [
                { "waitForThenClick": "#banner-cookie-setting-btn" },
                { "waitForVisible": "#settings-only-required-btn" },
                { "waitForThenClick": "#settings-only-required-btn" }
            ]
        }
    ]
}
