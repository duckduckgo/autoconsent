{
    "name": "auto_DE_acemate.ai_7mg",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://acemate.ai/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?acemate\\.ai/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body > div:not([id]) > button:nth-child(3):not([id])"
        }
    ],
    "detectPopup": [
        {
            "visible": "body > div:not([id]) > button:nth-child(3):not([id])"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > div:not([id]) > button:nth-child(3):not([id])",
            "comment": "Accept only necessary cookies"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > div:not([id]) > button:nth-child(3):not([id])",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
