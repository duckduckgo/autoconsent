{
    "name": "auto_CH_33d.ch_xad",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://33d.ch/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?33d\\.ch/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body > div#cookie-banner > div:not([id]) > div:nth-child(2):not([id]) > button:nth-child(1)#cookie-decline"
        }
    ],
    "detectPopup": [
        {
            "visible": "body > div#cookie-banner > div:not([id]) > div:nth-child(2):not([id]) > button:nth-child(1)#cookie-decline"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > div#cookie-banner > div:not([id]) > div:nth-child(2):not([id]) > button:nth-child(1)#cookie-decline",
            "comment": "Only essential cookies"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > div#cookie-banner > div:not([id]) > div:nth-child(2):not([id]) > button:nth-child(1)#cookie-decline",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
