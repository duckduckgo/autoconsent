{
    "name": "auto_DE_de.beta-layout.com_mvd",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://de.beta-layout.com/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?de\\.beta-layout\\.com/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body > div#content_cookie > div:not([id]) > button:nth-child(3):not([id])"
        }
    ],
    "detectPopup": [
        {
            "visible": "body > div#content_cookie > div:not([id]) > button:nth-child(3):not([id])"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > div#content_cookie > div:not([id]) > button:nth-child(3):not([id])",
            "comment": "Alle Cookies ablehnen"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > div#content_cookie > div:not([id]) > button:nth-child(3):not([id])",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
