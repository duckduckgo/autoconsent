{
    "name": "auto_GB_belmarresort.com_pmy",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://www.belmarresort.com/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?belmarresort\\.com/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body > div#cookie-consent-banner > button:nth-child(5)#btn-reject-all"
        }
    ],
    "detectPopup": [
        {
            "visible": "body > div#cookie-consent-banner > button:nth-child(5)#btn-reject-all"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > div#cookie-consent-banner > button:nth-child(5)#btn-reject-all",
            "comment": "Reject All"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > div#cookie-consent-banner > button:nth-child(5)#btn-reject-all",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
