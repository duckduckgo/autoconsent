{
    "name": "auto_CA_flytodoc.com_duz",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://flytodoc.com/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?flytodoc\\.com/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body > div[id^=\"radix-\"] > div:nth-child(2):not([id]) > div.flex.justify-between.gap-2.border-t.pt-2 > button:nth-child(1):not([id])"
        }
    ],
    "detectPopup": [
        {
            "visible": "body > div[id^=\"radix-\"] > div:nth-child(2):not([id]) > div.flex.justify-between.gap-2.border-t.pt-2 > button:nth-child(1):not([id])"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > div[id^=\"radix-\"] > div:nth-child(2):not([id]) > div.flex.justify-between.gap-2.border-t.pt-2 > button:nth-child(1):not([id])",
            "comment": "Reject All"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > div[id^=\"radix-\"] > div:nth-child(2):not([id]) > div.flex.justify-between.gap-2.border-t.pt-2 > button:nth-child(1):not([id])",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
