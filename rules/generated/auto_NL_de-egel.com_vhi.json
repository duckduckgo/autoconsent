{
    "name": "auto_NL_de-egel.com_vhi",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://de-egel.com/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?de-egel\\.com/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body > div#cookie-bar > a:nth-child(2):not([id])"
        }
    ],
    "detectPopup": [
        {
            "visible": "body > div#cookie-bar > a:nth-child(2):not([id])"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > div#cookie-bar > a:nth-child(2):not([id])",
            "comment": "Decline cookies"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > div#cookie-bar > a:nth-child(2):not([id])",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
