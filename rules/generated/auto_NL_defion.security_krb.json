    ],
    "test": [
        {
            "waitForVisible": "body > div:not([id])[data-testid=\"cookie-banner-root\"] > div:not([id])[data-testid=\"cookie-banner-card\"] > div:nth-child(2):not([id])[data-testid=\"cookie-banner-footer\"] > div:nth-child(1):not([id])[data-testid=\"cookie-banner-footer-sub-group\"] > button:nth-child(1):not([id])[data-testid=\"cookie-banner-reject-button\"]",
