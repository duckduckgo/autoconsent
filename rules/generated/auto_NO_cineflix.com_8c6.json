{
    "name": "auto_NO_cineflix.com_8c6",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://cineflix.com/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?cineflix\\.com/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body > div#cookie-banner > div:nth-child(4):not([id]) > button:not([id])"
        }
    ],
    "detectPopup": [
        {
            "visible": "body > div#cookie-banner > div:nth-child(4):not([id]) > button:not([id])"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > div#cookie-banner > div:nth-child(4):not([id]) > button:not([id])",
            "comment": "REJECT ALL COOKIES"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > div#cookie-banner > div:nth-child(4):not([id]) > button:not([id])",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
