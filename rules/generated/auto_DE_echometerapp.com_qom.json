{
    "name": "auto_DE_echometerapp.com_qom",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://echometerapp.com/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?echometerapp\\.com/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body > div#consent-banner > div:not([id]) > div:nth-child(4):not([id]) > a:nth-child(2)#decline-analytics-button"
        }
    ],
    "detectPopup": [
        {
            "visible": "body > div#consent-banner > div:not([id]) > div:nth-child(4):not([id]) > a:nth-child(2)#decline-analytics-button"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > div#consent-banner > div:not([id]) > div:nth-child(4):not([id]) > a:nth-child(2)#decline-analytics-button",
            "comment": "Decline"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > div#consent-banner > div:not([id]) > div:nth-child(4):not([id]) > a:nth-child(2)#decline-analytics-button",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
