{
    "name": "auto_AU_awesomeagents.ai_gtk",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://awesomeagents.ai/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?awesomeagents\\.ai/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body > div#consent-notice > button:nth-child(3):not([id])"
        }
    ],
    "detectPopup": [
        {
            "visible": "body > div#consent-notice > button:nth-child(3):not([id])"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > div#consent-notice > button:nth-child(3):not([id])",
            "comment": "DENY"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > div#consent-notice > button:nth-child(3):not([id])",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
