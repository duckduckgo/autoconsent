{
    "name": "auto_DE_aimlapi.com_dyk",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://aimlapi.com/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?aimlapi\\.com/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body > div#cookieConsentContainer > div:nth-child(3):not([id]) > button:nth-child(2):not([id])"
        }
    ],
    "detectPopup": [
        {
            "visible": "body > div#cookieConsentContainer > div:nth-child(3):not([id]) > button:nth-child(2):not([id])"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > div#cookieConsentContainer > div:nth-child(3):not([id]) > button:nth-child(2):not([id])",
            "comment": "Decline"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > div#cookieConsentContainer > div:nth-child(3):not([id]) > button:nth-child(2):not([id])",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
