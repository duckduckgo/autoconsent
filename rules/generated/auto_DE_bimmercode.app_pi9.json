{
    "name": "auto_DE_bimmercode.app_pi9",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://bimmercode.app/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?bimmercode\\.app/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body > main:not([id]) > div:nth-child(11)#cookies-note > div:nth-child(2):not([id]) > button:nth-child(2)#reject-cookies"
        }
    ],
    "detectPopup": [
        {
            "visible": "body > main:not([id]) > div:nth-child(11)#cookies-note > div:nth-child(2):not([id]) > button:nth-child(2)#reject-cookies"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > main:not([id]) > div:nth-child(11)#cookies-note > div:nth-child(2):not([id]) > button:nth-child(2)#reject-cookies",
            "comment": "Reject Cookies"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > main:not([id]) > div:nth-child(11)#cookies-note > div:nth-child(2):not([id]) > button:nth-child(2)#reject-cookies",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
