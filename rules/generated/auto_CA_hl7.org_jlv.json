{
    "name": "auto_CA_hl7.org_jlv",
    "vendorUrl": "https://www.hl7.org/",
    "cosmetic": false,
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?hl7\\.org/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body:not([id]) > div#hs-eu-cookie-confirmation > div#hs-eu-cookie-confirmation-inner > div:nth-child(4)#hs-en-cookie-confirmation-buttons-area > div#hs-eu-cookie-confirmation-button-group > a:nth-child(2)#hs-eu-decline-button"
        }
    ],
    "detectPopup": [
        {
            "visible": "body:not([id]) > div#hs-eu-cookie-confirmation > div#hs-eu-cookie-confirmation-inner > div:nth-child(4)#hs-en-cookie-confirmation-buttons-area > div#hs-eu-cookie-confirmation-button-group > a:nth-child(2)#hs-eu-decline-button"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "wait": 500
        },
        {
            "waitForThenClick": "body:not([id]) > div#hs-eu-cookie-confirmation > div#hs-eu-cookie-confirmation-inner > div:nth-child(4)#hs-en-cookie-confirmation-buttons-area > div#hs-eu-cookie-confirmation-button-group > a:nth-child(2)#hs-eu-decline-button",
            "comment": "Decline"
        }
    ],
    "test": [
        {
            "waitForVisible": "body:not([id]) > div#hs-eu-cookie-confirmation > div#hs-eu-cookie-confirmation-inner > div:nth-child(4)#hs-en-cookie-confirmation-buttons-area > div#hs-eu-cookie-confirmation-button-group > a:nth-child(2)#hs-eu-decline-button",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
