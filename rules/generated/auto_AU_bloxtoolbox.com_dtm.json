{
    "name": "auto_AU_bloxtoolbox.com_dtm",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://bloxtoolbox.com/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?bloxtoolbox\\.com/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body > div#cookieConsent > div:not([id]) > div:nth-child(2):not([id]) > button:nth-child(2)#cookieDecline"
        }
    ],
    "detectPopup": [
        {
            "visible": "body > div#cookieConsent > div:not([id]) > div:nth-child(2):not([id]) > button:nth-child(2)#cookieDecline"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > div#cookieConsent > div:not([id]) > div:nth-child(2):not([id]) > button:nth-child(2)#cookieDecline",
            "comment": "Decline"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > div#cookieConsent > div:not([id]) > div:nth-child(2):not([id]) > button:nth-child(2)#cookieDecline",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
