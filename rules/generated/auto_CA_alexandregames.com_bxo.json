{
    "name": "auto_CA_alexandregames.com_bxo",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://alexandregames.com/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?alexandregames\\.com/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body > div#cookie-banner > div:nth-child(2):not([id]) > button:nth-child(2)#reject-cookies"
        }
    ],
    "detectPopup": [
        {
            "visible": "body > div#cookie-banner > div:nth-child(2):not([id]) > button:nth-child(2)#reject-cookies"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > div#cookie-banner > div:nth-child(2):not([id]) > button:nth-child(2)#reject-cookies",
            "comment": "Reject All"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > div#cookie-banner > div:nth-child(2):not([id]) > button:nth-child(2)#reject-cookies",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
