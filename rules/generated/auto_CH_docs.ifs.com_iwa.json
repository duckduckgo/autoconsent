{
    "name": "auto_CH_docs.ifs.com_iwa",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://docs.ifs.com/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?docs\\.ifs\\.com/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body > div#cookie-consent-toast > div:nth-child(3):not([id]) > button:nth-child(2):not([id])"
        }
    ],
    "detectPopup": [
        {
            "visible": "body > div#cookie-consent-toast > div:nth-child(3):not([id]) > button:nth-child(2):not([id])"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > div#cookie-consent-toast > div:nth-child(3):not([id]) > button:nth-child(2):not([id])",
            "comment": "Decline"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > div#cookie-consent-toast > div:nth-child(3):not([id]) > button:nth-child(2):not([id])",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
