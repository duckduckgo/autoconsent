{
    "name": "auto_AU_anker.com_a3f",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "https://www.anker.com/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?anker\\.com/"
    },
    "prehideSelectors": ["#cookie-consent"],
    "detectCmp": [
        {
            "exists": "#cookie-consent #cc-main"
        }
    ],
    "detectPopup": [
        {
            "visible": "#cookie-consent #cc-main .cm--box"
        }
    ],
    "optIn": [
        {
            "waitForThenClick": "#cookie-consent .cm__btn[data-role=all]"
        }
    ],
    "optOut": [
        {
            "waitForThenClick": "#cookie-consent .cm__btn[data-role=necessary]"
        }
    ],
    "test": [
        {
            "cookieContains": "cc_cookie="
        }
    ]
}
