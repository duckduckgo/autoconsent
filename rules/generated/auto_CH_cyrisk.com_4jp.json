        {
            "waitForThenClick": "body > aside#cookieBanner > div:nth-child(2):not([id]) > div:nth-child(3):not([id]) > button:nth-child(2)#rejectAllBtn",
            "comment": "Reject All"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > aside#cookieBanner > div:nth-child(2):not([id]) > div:nth-child(3):not([id]) > button:nth-child(2)#rejectAllBtn",
            "timeout": 1000,
            "check": "none"
        }
    ]
