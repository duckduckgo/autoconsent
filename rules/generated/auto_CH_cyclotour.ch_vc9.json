{
    "name": "auto_CH_cyclotour.ch_vc9",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://cyclotour.ch/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?cyclotour\\.ch/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body > div#cookie-consent-banner > div:not([id]) > div:nth-child(2):not([id]) > button:nth-child(2)#btn-reject-all"
        }
    ],
    "detectPopup": [
        {
            "visible": "body > div#cookie-consent-banner > div:not([id]) > div:nth-child(2):not([id]) > button:nth-child(2)#btn-reject-all"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > div#cookie-consent-banner > div:not([id]) > div:nth-child(2):not([id]) > button:nth-child(2)#btn-reject-all",
            "comment": "Reject all"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > div#cookie-consent-banner > div:not([id]) > div:nth-child(2):not([id]) > button:nth-child(2)#btn-reject-all",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
