{
    "name": "auto_GB_web.monzo.com_scl",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://web.monzo.com/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?auth\\.monzo\\.com/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body > div#__next > dialog:nth-child(4):not([id])[data-testid=\"cookie-banner\"] > div:nth-child(3):not([id]) > button:nth-child(2):not([id])[data-testid=\"reject-cookies\"]"
        }
    ],
    "detectPopup": [
        {
            "visible": "body > div#__next > dialog:nth-child(4):not([id])[data-testid=\"cookie-banner\"] > div:nth-child(3):not([id]) > button:nth-child(2):not([id])[data-testid=\"reject-cookies\"]"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > div#__next > dialog:nth-child(4):not([id])[data-testid=\"cookie-banner\"] > div:nth-child(3):not([id]) > button:nth-child(2):not([id])[data-testid=\"reject-cookies\"]",
            "comment": "Reject all"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > div#__next > dialog:nth-child(4):not([id])[data-testid=\"cookie-banner\"] > div:nth-child(3):not([id]) > button:nth-child(2):not([id])[data-testid=\"reject-cookies\"]",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
