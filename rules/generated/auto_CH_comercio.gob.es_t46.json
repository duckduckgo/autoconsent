{
    "name": "auto_CH_comercio.gob.es_t46",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://comercio.gob.es/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?comercio\\.gob\\.es/"
