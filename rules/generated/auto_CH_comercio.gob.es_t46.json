    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body > div#cookieChoiceInfo > div:nth-child(2):not([id]) > button:nth-child(2)#RejectAll"
        }
    ],
    "detectPopup": [
        {
            "visible": "body > div#cookieChoiceInfo > div:nth-child(2):not([id]) > button:nth-child(2)#RejectAll"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > div#cookieChoiceInfo > div:nth-child(2):not([id]) > button:nth-child(2)#RejectAll",
            "comment": "Reject all"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > div#cookieChoiceInfo > div:nth-child(2):not([id]) > button:nth-child(2)#RejectAll",
            "timeout": 1000,
            "check": "none"
        }
    ]
