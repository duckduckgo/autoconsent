{
    "name": "auto_GB_adults.wiltshire.gov.uk_gdm",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://adults.wiltshire.gov.uk/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?adults\\.wiltshire\\.gov\\.uk/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body > div#system-dialogs > div:nth-child(2)#js-cookie-banner-panel > div:not([id]) > div:nth-child(2):not([id]) > button:nth-child(2)#cookiebanner-rejectionbutton"
        }
    ],
    "detectPopup": [
        {
            "visible": "body > div#system-dialogs > div:nth-child(2)#js-cookie-banner-panel > div:not([id]) > div:nth-child(2):not([id]) > button:nth-child(2)#cookiebanner-rejectionbutton"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > div#system-dialogs > div:nth-child(2)#js-cookie-banner-panel > div:not([id]) > div:nth-child(2):not([id]) > button:nth-child(2)#cookiebanner-rejectionbutton",
            "comment": "Reject cookies"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > div#system-dialogs > div:nth-child(2)#js-cookie-banner-panel > div:not([id]) > div:nth-child(2):not([id]) > button:nth-child(2)#cookiebanner-rejectionbutton",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
