{
    "name": "auto_DE_developers.deepl.com_dxx",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://developers.deepl.com/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?developers\\.deepl\\.com/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body > div#cookie-banner > div:nth-child(2)#cookie-banner-buttons > button:nth-child(1)#cookie-reject"
        }
    ],
    "detectPopup": [
        {
            "visible": "body > div#cookie-banner > div:nth-child(2)#cookie-banner-buttons > button:nth-child(1)#cookie-reject"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > div#cookie-banner > div:nth-child(2)#cookie-banner-buttons > button:nth-child(1)#cookie-reject",
            "comment": "Reject"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > div#cookie-banner > div:nth-child(2)#cookie-banner-buttons > button:nth-child(1)#cookie-reject",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
