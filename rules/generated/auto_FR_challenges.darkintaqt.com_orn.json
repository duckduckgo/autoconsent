{
    "name": "auto_FR_challenges.darkintaqt.com_orn",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://challenges.darkintaqt.com/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?challenges\\.darkintaqt\\.com/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body > section#_cc_m_root > div#_cc_m_container > div:nth-child(5)#_cc_m_buttons > button:nth-child(1):not([id])"
        }
    ],
    "detectPopup": [
        {
            "visible": "body > section#_cc_m_root > div#_cc_m_container > div:nth-child(5)#_cc_m_buttons > button:nth-child(1):not([id])"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > section#_cc_m_root > div#_cc_m_container > div:nth-child(5)#_cc_m_buttons > button:nth-child(1):not([id])",
            "comment": "Decline"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > section#_cc_m_root > div#_cc_m_container > div:nth-child(5)#_cc_m_buttons > button:nth-child(1):not([id])",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
