{
    "name": "auto_DE_airnergy.com_sh4",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://airnergy.com/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?airnergy\\.com/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body > div:not([id]) > div#cookieConsent > p:not([id]) > button:nth-child(3)#declineCookies"
        }
    ],
    "detectPopup": [
        {
            "visible": "body > div:not([id]) > div#cookieConsent > p:not([id]) > button:nth-child(3)#declineCookies"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > div:not([id]) > div#cookieConsent > p:not([id]) > button:nth-child(3)#declineCookies",
            "comment": "Nur essentielle"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > div:not([id]) > div#cookieConsent > p:not([id]) > button:nth-child(3)#declineCookies",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
