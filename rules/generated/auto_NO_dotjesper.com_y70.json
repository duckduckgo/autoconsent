{
    "name": "auto_NO_dotjesper.com_y70",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://dotjesper.com/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?dotjesper\\.com/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body > div#consent > span:nth-child(2):not([id]) > button:nth-child(2)#consent-deny"
        }
    ],
    "detectPopup": [
        {
            "visible": "body > div#consent > span:nth-child(2):not([id]) > button:nth-child(2)#consent-deny"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > div#consent > span:nth-child(2):not([id]) > button:nth-child(2)#consent-deny",
            "comment": "Deny"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > div#consent > span:nth-child(2):not([id]) > button:nth-child(2)#consent-deny",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
