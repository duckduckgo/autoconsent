    ],
    "test": [
        {
            "waitForVisible": "body > header:not([id]) > div:nth-child(1)#cookie-banner > div:nth-child(4):not([id]) > button:nth-child(1)#reject-cookies",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
