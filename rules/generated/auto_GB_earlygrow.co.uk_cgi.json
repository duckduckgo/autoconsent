{
    "name": "auto_GB_earlygrow.co.uk_cgi",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://earlygrow.co.uk/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?earlygrow\\.co\\.uk/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body > div#cookie-banner > button:nth-child(3)#reject-all"
        }
    ],
    "detectPopup": [
        {
            "visible": "body > div#cookie-banner > button:nth-child(3)#reject-all"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > div#cookie-banner > button:nth-child(3)#reject-all",
            "comment": "Reject All"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > div#cookie-banner > button:nth-child(3)#reject-all",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
