{
    "name": "auto_GB_blanchardsbailey.co.uk_max",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://blanchardsbailey.co.uk/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?blanchardsbailey\\.co\\.uk/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body > div#cookie-consent-banner > div:nth-child(3):not([id]) > span:nth-child(3):not([id])"
        }
    ],
    "detectPopup": [
        {
            "visible": "body > div#cookie-consent-banner > div:nth-child(3):not([id]) > span:nth-child(3):not([id])"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > div#cookie-consent-banner > div:nth-child(3):not([id]) > span:nth-child(3):not([id])",
            "comment": "I REJECT ALL COOKIES"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > div#cookie-consent-banner > div:nth-child(3):not([id]) > span:nth-child(3):not([id])",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
