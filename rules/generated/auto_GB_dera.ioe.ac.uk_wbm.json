{
    "name": "auto_GB_dera.ioe.ac.uk_wbm",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://dera.ioe.ac.uk/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?dera\\.ioe\\.ac\\.uk/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body > div#ep_cookies_banner > div:nth-child(2):not([id]) > button:nth-child(2)#ep_cookies_reject"
        }
    ],
    "detectPopup": [
        {
            "visible": "body > div#ep_cookies_banner > div:nth-child(2):not([id]) > button:nth-child(2)#ep_cookies_reject"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > div#ep_cookies_banner > div:nth-child(2):not([id]) > button:nth-child(2)#ep_cookies_reject",
            "comment": "Reject non-essential cookies"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > div#ep_cookies_banner > div:nth-child(2):not([id]) > button:nth-child(2)#ep_cookies_reject",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
