{
    "name": "auto_GB_floodassist.co.uk_nol",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://floodassist.co.uk/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?floodassist\\.co\\.uk/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body > div#cookieConsent > div:nth-child(2):not([id]) > button:nth-child(1):not([id])"
        }
    ],
    "detectPopup": [
        {
            "visible": "body > div#cookieConsent > div:nth-child(2):not([id]) > button:nth-child(1):not([id])"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > div#cookieConsent > div:nth-child(2):not([id]) > button:nth-child(1):not([id])",
            "comment": "Decline"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > div#cookieConsent > div:nth-child(2):not([id]) > button:nth-child(1):not([id])",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
