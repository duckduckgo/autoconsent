{
    "name": "auto_GB_simlab.co.uk_hgk",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://www.simlab.co.uk/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?simlab\\.co\\.uk/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body > div#cookiePopup > div:nth-child(2):not([id]) > button:nth-child(3)#acceptCookie"
        }
    ],
    "detectPopup": [
        {
            "visible": "body > div#cookiePopup > div:nth-child(2):not([id]) > button:nth-child(3)#acceptCookie"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > div#cookiePopup > div:nth-child(2):not([id]) > button:nth-child(3)#acceptCookie",
            "comment": "Accept Essential Cookies"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > div#cookiePopup > div:nth-child(2):not([id]) > button:nth-child(3)#acceptCookie",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
