{
    "name": "auto_GB_archives.lse.ac.uk_3dm",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://archives.lse.ac.uk/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?archives\\.lse\\.ac\\.uk/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body > div#cookie-message > div:nth-child(2):not([id]) > a:nth-child(2):not([id])"
        }
    ],
    "detectPopup": [
        {
            "visible": "body > div#cookie-message > div:nth-child(2):not([id]) > a:nth-child(2):not([id])"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > div#cookie-message > div:nth-child(2):not([id]) > a:nth-child(2):not([id])",
            "comment": "Only essential cookies"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > div#cookie-message > div:nth-child(2):not([id]) > a:nth-child(2):not([id])",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
