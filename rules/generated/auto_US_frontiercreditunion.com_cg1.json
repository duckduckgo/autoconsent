{
    "name": "auto_US_frontiercreditunion.com_cg1",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://frontiercreditunion.com/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?frontiercreditunion\\.com/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body > div:not([id]) > div:nth-child(23)#cookie-banner > button:nth-child(3)#cookie-reject-all"
        }
    ],
    "detectPopup": [
        {
            "visible": "body > div:not([id]) > div:nth-child(23)#cookie-banner > button:nth-child(3)#cookie-reject-all"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > div:not([id]) > div:nth-child(23)#cookie-banner > button:nth-child(3)#cookie-reject-all",
            "comment": "Reject All"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > div:not([id]) > div:nth-child(23)#cookie-banner > button:nth-child(3)#cookie-reject-all",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
