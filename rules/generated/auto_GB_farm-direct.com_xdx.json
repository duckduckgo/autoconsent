{
    "name": "auto_GB_farm-direct.com_xdx",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://farm-direct.com/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?farm-direct\\.com/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body > div#consentBanner > div:nth-child(2):not([id]) > button:nth-child(3):not([id])"
        }
    ],
    "detectPopup": [
        {
            "visible": "body > div#consentBanner > div:nth-child(2):not([id]) > button:nth-child(3):not([id])"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > div#consentBanner > div:nth-child(2):not([id]) > button:nth-child(3):not([id])",
            "comment": "Reject All"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > div#consentBanner > div:nth-child(2):not([id]) > button:nth-child(3):not([id])",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
