        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > div#cookies > div:not([id]) > div:nth-child(2):not([id]) > button:nth-child(1)#rejeitarCookiesNaoNecessarios",
            "comment": "Rejeitar cookies não necessários"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > div#cookies > div:not([id]) > div:nth-child(2):not([id]) > button:nth-child(1)#rejeitarCookiesNaoNecessarios",
