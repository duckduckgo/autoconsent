{
    "name": "auto_CA_elbowliquor.ca_4kv",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://elbowliquor.ca/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?elbowliquor\\.ca/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body > div#cookie-banner > button:nth-child(2)#reject-cookies"
        }
    ],
    "detectPopup": [
        {
            "visible": "body > div#cookie-banner > button:nth-child(2)#reject-cookies"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > div#cookie-banner > button:nth-child(2)#reject-cookies",
            "comment": "Reject"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > div#cookie-banner > button:nth-child(2)#reject-cookies",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
