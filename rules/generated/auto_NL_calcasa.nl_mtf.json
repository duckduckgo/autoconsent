{
    "name": "auto_NL_calcasa.nl_mtf",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://calcasa.nl/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?calcasa\\.nl/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body > div#consent-banner-wrapper > div:nth-child(3)#consent-banner > div:nth-child(3):not([id]) > button:nth-child(2):not([id])"
        }
    ],
    "detectPopup": [
        {
            "visible": "body > div#consent-banner-wrapper > div:nth-child(3)#consent-banner > div:nth-child(3):not([id]) > button:nth-child(2):not([id])"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > div#consent-banner-wrapper > div:nth-child(3)#consent-banner > div:nth-child(3):not([id]) > button:nth-child(2):not([id])",
            "comment": "Weigeren"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > div#consent-banner-wrapper > div:nth-child(3)#consent-banner > div:nth-child(3):not([id]) > button:nth-child(2):not([id])",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
