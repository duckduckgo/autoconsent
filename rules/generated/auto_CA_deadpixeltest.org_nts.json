{
    "name": "auto_CA_deadpixeltest.org_nts",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://deadpixeltest.org/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?deadpixeltest\\.org/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body > div#cookie-consent-message > div:nth-child(2):not([id]) > div:nth-child(3):not([id])"
        }
    ],
    "detectPopup": [
        {
            "visible": "body > div#cookie-consent-message > div:nth-child(2):not([id]) > div:nth-child(3):not([id])"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > div#cookie-consent-message > div:nth-child(2):not([id]) > div:nth-child(3):not([id])",
            "comment": "Refuse all"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > div#cookie-consent-message > div:nth-child(2):not([id]) > div:nth-child(3):not([id])",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
