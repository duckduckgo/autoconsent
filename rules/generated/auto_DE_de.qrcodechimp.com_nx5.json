{
    "name": "auto_DE_de.qrcodechimp.com_nx5",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://de.qrcodechimp.com/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?de\\.qrcodechimp\\.com/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body > div#cookieBannerDiv > div:nth-child(2):not([id]) > a:nth-child(2):not([id])"
        }
    ],
    "detectPopup": [
        {
            "visible": "body > div#cookieBannerDiv > div:nth-child(2):not([id]) > a:nth-child(2):not([id])"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > div#cookieBannerDiv > div:nth-child(2):not([id]) > a:nth-child(2):not([id])",
            "comment": "Nur notwendige Cookies"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > div#cookieBannerDiv > div:nth-child(2):not([id]) > a:nth-child(2):not([id])",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
