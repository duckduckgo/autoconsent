{
    "name": "auto_GB_britishnotes.co.uk_fvu",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://britishnotes.co.uk/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?britishnotes\\.co\\.uk/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body > div#cookieConsent > form:not([id]) > button:nth-child(5)#reject-cookies"
        }
    ],
    "detectPopup": [
        {
            "visible": "body > div#cookieConsent > form:not([id]) > button:nth-child(5)#reject-cookies"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > div#cookieConsent > form:not([id]) > button:nth-child(5)#reject-cookies",
            "comment": "Accept only necessary"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > div#cookieConsent > form:not([id]) > button:nth-child(5)#reject-cookies",
            "timeout": 1000,
            "check": "none"
        }
    ]
