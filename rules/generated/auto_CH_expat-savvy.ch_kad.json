{
    "name": "auto_CH_expat-savvy.ch_kad",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://expat-savvy.ch/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?expat-savvy\\.ch/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body > div#cookie-banner > div:not([id]) > div:nth-child(3):not([id]) > button:nth-child(1)#cookie-reject"
        }
    ],
    "detectPopup": [
        {
            "visible": "body > div#cookie-banner > div:not([id]) > div:nth-child(3):not([id]) > button:nth-child(1)#cookie-reject"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > div#cookie-banner > div:not([id]) > div:nth-child(3):not([id]) > button:nth-child(1)#cookie-reject",
            "comment": "Essentials Only"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > div#cookie-banner > div:not([id]) > div:nth-child(3):not([id]) > button:nth-child(1)#cookie-reject",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
