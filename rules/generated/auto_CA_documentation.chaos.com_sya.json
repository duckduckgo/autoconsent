{
    "name": "auto_CA_documentation.chaos.com_sya",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://documentation.chaos.com/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?documentation\\.chaos\\.com/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body > div:not([id]) > div#cookie_dialog > div:nth-child(4):not([id]) > button:nth-child(2):not([id])"
        }
    ],
    "detectPopup": [
        {
            "visible": "body > div:not([id]) > div#cookie_dialog > div:nth-child(4):not([id]) > button:nth-child(2):not([id])"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > div:not([id]) > div#cookie_dialog > div:nth-child(4):not([id]) > button:nth-child(2):not([id])",
            "comment": "Accept required cookies only"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > div:not([id]) > div#cookie_dialog > div:nth-child(4):not([id]) > button:nth-child(2):not([id])",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
