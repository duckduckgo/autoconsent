{
    "name": "auto_AU_flysaa.com_qsm",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "https://www.flysaa.com/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?flysaa\\.com/"
    },
    "prehideSelectors": ["#cookiesPortletDiv"],
    "detectCmp": [
        {
            "exists": "#cookiesPortletDiv"
        }
    ],
    "detectPopup": [
        {
            "visible": "#cookiesPortletDiv .cookie-buttons"
        }
    ],
    "optIn": [
        {
            "waitForThenClick": "#cookiesPortletDiv button[name='acceptAll']"
        }
    ],
    "optOut": [
        {
            "waitForThenClick": "#cookiesPortletDiv button[aria-label='Only Mandatory']",
            "comment": "Only Mandatory"
        }
    ],
    "test": [
        {
            "waitForVisible": "#cookiesPortletDiv .cookie-buttons",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
