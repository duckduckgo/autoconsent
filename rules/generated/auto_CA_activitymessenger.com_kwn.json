{
    "name": "auto_CA_activitymessenger.com_kwn",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://activitymessenger.com/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?activitymessenger\\.com/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body > div:not([id]) > div:nth-child(24)#cookie-popup > div:nth-child(3):not([id]) > button:nth-child(1)#cookie-reject"
        }
    ],
    "detectPopup": [
        {
            "visible": "body > div:not([id]) > div:nth-child(24)#cookie-popup > div:nth-child(3):not([id]) > button:nth-child(1)#cookie-reject"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > div:not([id]) > div:nth-child(24)#cookie-popup > div:nth-child(3):not([id]) > button:nth-child(1)#cookie-reject",
            "comment": "Reject"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > div:not([id]) > div:nth-child(24)#cookie-popup > div:nth-child(3):not([id]) > button:nth-child(1)#cookie-reject",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
