{
    "name": "auto_CA_byo.com_flw",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://byo.com/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?byo\\.com/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body > div#cookie-law-info-bar > span:not([id]) > a:nth-child(2)#CONSTANT_OPEN_URL"
        }
    ],
    "detectPopup": [
        {
            "visible": "body > div#cookie-law-info-bar > span:not([id]) > a:nth-child(2)#CONSTANT_OPEN_URL"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > div#cookie-law-info-bar > span:not([id]) > a:nth-child(2)#CONSTANT_OPEN_URL",
            "comment": "Reject"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > div#cookie-law-info-bar > span:not([id]) > a:nth-child(2)#CONSTANT_OPEN_URL",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
