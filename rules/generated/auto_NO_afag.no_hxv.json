{
    "name": "auto_NO_afag.no_hxv",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://afag.no/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?afag\\.no/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body > div#teha-cookie-consent > div:not([id]) > div:nth-child(4):not([id]) > button:nth-child(2):not([id])"
        }
    ],
    "detectPopup": [
        {
            "visible": "body > div#teha-cookie-consent > div:not([id]) > div:nth-child(4):not([id]) > button:nth-child(2):not([id])"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > div#teha-cookie-consent > div:not([id]) > div:nth-child(4):not([id]) > button:nth-child(2):not([id])",
            "comment": "Disable cookies"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > div#teha-cookie-consent > div:not([id]) > div:nth-child(4):not([id]) > button:nth-child(2):not([id])",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
