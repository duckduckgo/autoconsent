        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > div#dsV3Overlay > div#dsV3Dialog > div:nth-child(7):not([id]) > button:nth-child(2):not([id])",
            "comment": "Alle ablehnen"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > div#dsV3Overlay > div#dsV3Dialog > div:nth-child(7):not([id]) > button:nth-child(2):not([id])",
            "timeout": 1000,
            "check": "none"
        }
    ]
