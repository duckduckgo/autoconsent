{
    "name": "auto_DE_adelindistherme.de_abo",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://adelindistherme.de/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?adelindistherme\\.de/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body > div#dsV3Overlay > div#dsV3Dialog > div:nth-child(7):not([id]) > button:nth-child(2):not([id])"
        }
    ],
    "detectPopup": [
        {
