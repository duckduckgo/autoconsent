        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > div#cnilbanner > div:not([id]) > div:nth-child(2):not([id]) > a:nth-child(3):not([id])",
            "comment": "TOUT REFUSER"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > div#cnilbanner > div:not([id]) > div:nth-child(2):not([id]) > a:nth-child(3):not([id])",
            "timeout": 1000,
            "check": "none"
        }
    ]
