{
    "name": "auto_NL_belastbaar.com_sfk",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://belastbaar.com/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?belastbaar\\.com/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body > div:not([id])[data-testid=\"cookie-banner\"] > div:not([id]) > div:not([id]) > div:nth-child(2):not([id]) > button:nth-child(2):not([id])[data-testid=\"button-reject-all\"]"
        }
    ],
    "detectPopup": [
        {
            "visible": "body > div:not([id])[data-testid=\"cookie-banner\"] > div:not([id]) > div:not([id]) > div:nth-child(2):not([id]) > button:nth-child(2):not([id])[data-testid=\"button-reject-all\"]"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > div:not([id])[data-testid=\"cookie-banner\"] > div:not([id]) > div:not([id]) > div:nth-child(2):not([id]) > button:nth-child(2):not([id])[data-testid=\"button-reject-all\"]",
            "comment": "Alles Afwijzen"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > div:not([id])[data-testid=\"cookie-banner\"] > div:not([id]) > div:not([id]) > div:nth-child(2):not([id]) > button:nth-child(2):not([id])[data-testid=\"button-reject-all\"]",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
