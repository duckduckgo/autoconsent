{
    "name": "auto_US_careers.aldi.us_s5y",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://careers.aldi.us/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?careers\\.aldi\\.us/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body > div#igdpr-alert > button:nth-child(3)#igdpr-reject-button"
        }
    ],
    "detectPopup": [
        {
            "visible": "body > div#igdpr-alert > button:nth-child(3)#igdpr-reject-button"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > div#igdpr-alert > button:nth-child(3)#igdpr-reject-button",
            "comment": "Reject"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > div#igdpr-alert > button:nth-child(3)#igdpr-reject-button",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
