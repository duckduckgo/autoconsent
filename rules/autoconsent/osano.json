{
    "name": "Osano",
    "_metadata": {
        "vendorUrl": "https://www.osano.com/"
    },
    "prehideSelectors": [".osano-cm-window__dialog.osano-cm-dialog,.osano-cm-dialog:not(.osano-cm-dialog--hidden)"],
    "detectCmp": [
        {
            "any": [{ "eval": "EVAL_OSANO_DETECT_CMP" }, { "exists": ".osano-cm-window" }]
        }
    ],
    "detectPopup": [
        {
            "any": [
                { "eval": "EVAL_OSANO_POPUP_OPEN" },
                { "eval": "EVAL_OSANO_DIALOG_OPEN" },
                { "visible": ".osano-cm-window .osano-cm-button--type_deny" },
                { "visible": ".osano-cm-window .osano-cm-button--type_accept" },
                { "visible": ".osano-cm-window .osano-cm-manage" }
            ]
        }
    ],
    "optOut": [
        {
            "if": {
                "visible": ".osano-cm-window .osano-cm-button--type_deny,button[class*=\"osano-cm-deny\"],button[class*=\"osano-cm-reject\"],.osano-cm-denyAll,.osano-cm-deny",
                "check": "any"
            },
            "then": [
                {
                    "waitForThenClick": ".osano-cm-window .osano-cm-button--type_deny,button[class*=\"osano-cm-deny\"],button[class*=\"osano-cm-reject\"],.osano-cm-denyAll,.osano-cm-deny"
                }
            ],
            "else": [
                {
                    "if": {
                        "visible": ".osano-cm-window .osano-cm-manage,button.osano-cm-manage",
                        "check": "any"
                    },
                    "then": [
                        { "waitForThenClick": ".osano-cm-window .osano-cm-manage,button.osano-cm-manage" },
                        { "wait": 500 },
                        { "eval": "EVAL_OSANO_UNCHECK_OPTIONAL_COOKIES" },
                        { "waitForThenClick": ".osano-cm-window .osano-cm-save,button.osano-cm-save" }
                    ],
                    "else": [{ "eval": "EVAL_OSANO_OPTOUT_CLOSE_ONLY" }]
                }
            ]
        }
    ],
    "optIn": [
        {
            "if": {
                "visible": ".osano-cm-window .osano-cm-button--type_accept,button[class*=\"osano-cm-acceptAll\"],button[class*=\"osano-cm-accept\"]",
                "check": "any"
            },
            "then": [
                {
                    "waitForThenClick": ".osano-cm-window .osano-cm-button--type_accept,button[class*=\"osano-cm-acceptAll\"],button[class*=\"osano-cm-accept\"]"
                }
            ],
            "else": [
                {
                    "if": {
                        "visible": ".osano-cm-window .osano-cm-manage,button.osano-cm-manage",
                        "check": "any"
                    },
                    "then": [
                        { "waitForThenClick": ".osano-cm-window .osano-cm-manage,button.osano-cm-manage" },
                        { "wait": 500 },
                        { "eval": "EVAL_OSANO_CHECK_OPTIONAL_COOKIES" },
                        { "waitForThenClick": ".osano-cm-window .osano-cm-save,button.osano-cm-save" }
                    ],
                    "else": [{ "eval": "EVAL_OSANO_OPTIN" }]
                }
            ]
        }
    ],
    "test": [{ "eval": "EVAL_OSANO_TEST" }]
}
