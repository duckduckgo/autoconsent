{
    "name": "progameguides.com",
    "vendorUrl": "https://progameguides.com/",
    "cosmetic": false,
    "runContext": {
        "urlPattern": "^https://([^/]+\\.)?progameguides\\.com/"
    },
    "prehideSelectors": ["#bc-cmp-banner-container"],
    "detectCmp": [
        {
            "exists": "#bc-cmp-banner"
        }
    ],
    "detectPopup": [
        {
            "visible": "#bc-cmp-banner"
        }
    ],
    "optIn": [
        {
            "waitForThenClick": "#bc-cmp-banner [data-action=\"accept-all\"]"
        }
    ],
    "optOut": [
        {
            "waitForThenClick": "#bc-cmp-banner [data-action=\"reject-all\"]"
        }
    ],
    "test": [
        {
            "visible": "#bc-cmp-banner",
            "check": "none"
        }
    ]
}
