{
    "name": "burpee.com",
    "prehideSelectors": [".cookie-modal", "#notice-cookie-block"],
    "detectCmp": [{ "exists": "#notice-cookie-block" }],
    "detectPopup": [{ "visible": "#html-body #notice-cookie-block" }],
    "optIn": [{ "waitForThenClick": "#btn-cookie-allow" }],
    "optOut": [
        {
            "if": { "exists": "#btn-cookie-manage" },
            "then": [
                { "waitForThenClick": "#btn-cookie-manage" },
                { "click": "#notice-cookie-block input:checked", "all": true },
                { "click": "#btn-cookie-save" }
            ],
            "else": [
                {
                    "if": { "exists": "#btn-manage-cookie-save-preferences" },
                    "then": [
                        { "waitForThenClick": "#btn-manage-cookie" },
                        { "waitForVisible": "#cookie-text-popup" },
                        { "click": "#cookie-text-popup input[type=\"checkbox\"]:checked", "all": true, "optional": true },
                        { "waitForThenClick": "#btn-manage-cookie-save-preferences" }
                    ],
                    "else": [
                        {
                            "hide": "#html-body #notice-cookie-block, #notice-cookie, body :is(div.fixed.inset-0:has(> #notice-cookie-block))"
                        }
                    ]
                }
            ]
        }
    ]
}
