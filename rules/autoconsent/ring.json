{
    "name": "ring",
    "vendorUrl": "https://ring.com/",
    "runContext": {
        "urlPattern": "ring\\.com"
    },
    "prehideSelectors": [".consent-banner"],
    "detectCmp": [{ "exists": "script#consent-script[src*=\"consent-manager\"]" }],
    "detectPopup": [{ "visible": ".consent-banner .consent-banner-buttons" }],
    "optIn": [{ "waitForThenClick": ".consent--accept" }],
    "optOut": [
        {
            "if": { "exists": ".consent--reject" },
            "then": [{ "waitForThenClick": ".consent--reject" }],
            "else": [
                { "waitForThenClick": ".consent--manage" },
                { "wait": 500 },
                { "click": ".third-party.active", "all": true, "optional": true },
                { "waitForThenClick": ".consent-save" }
            ]
        }
    ],
    "test": [{ "visible": ".consent-banner", "check": "none" }, { "cookieContains": "privacy-banner-clicked=true" }]
}
