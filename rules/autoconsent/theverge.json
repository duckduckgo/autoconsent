{
    "name": "theverge",
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https://(www\\.)?theverge\\.com"
    },
    "intermediate": false,
    "prehideSelectors": ["#onetrust-banner-sdk", "#onetrust-consent-sdk", ".onetrust-pc-dark-filter"],
    "detectCmp": [{ "exists": "#onetrust-banner-sdk" }],
    "detectPopup": [{ "visible": "#onetrust-banner-sdk" }],
    "optIn": [{ "waitForThenClick": "#onetrust-accept-btn-handler", "timeout": 5000 }],
    "optOut": [
        {
            "if": { "exists": "#onetrust-reject-all-handler" },
            "then": [{ "waitForThenClick": "#onetrust-reject-all-handler", "timeout": 5000 }],
            "else": [
                { "waitForThenClick": "#onetrust-pc-btn-handler", "timeout": 5000 },
                { "waitForThenClick": "#onetrust-consent-sdk .save-preference-btn-handler", "timeout": 5000 }
            ]
        },
        { "waitForVisible": "#onetrust-banner-sdk", "timeout": 5000, "check": "none" }
    ],
    "test": [{ "cookieContains": "OptanonAlertBoxClosed" }]
}
