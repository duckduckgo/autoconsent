{
    "name": "npo-ccm",
    "prehideSelectors": ["ccm-notification"],
    "detectCmp": [
        {
            "exists": "ccm-notification"
        }
    ],
    "detectPopup": [
        {
            "visible": ["ccm-notification"]
        }
    ],
    "optIn": [
        {
            "if": { "exists": ["ccm-notification", ".ccm_btn--accept-all"] },
            "then": [{ "waitForThenClick": ["ccm-notification", ".ccm_btn--accept-all"] }],
            "else": [{ "waitForThenClick": ["ccm-notification", "#ccm_close"] }]
        }
    ],
    "optOut": [
        {
            "if": { "exists": ["ccm-notification", ".ccm_btn--save"] },
            "then": [
                { "click": ["ccm-notification", "input[type=\"radio\"][value=\"false\"]"], "all": true },
                { "waitForThenClick": ["ccm-notification", ".ccm_btn--save:not(.ccm_btn_disabled)"] }
            ],
            "else": [{ "hide": "ccm-notification" }]
        }
    ]
}
