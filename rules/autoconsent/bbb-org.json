{
    "name": "bbb-org",
    "vendorUrl": "https://www.bbb.org/",
    "cosmetic": true,
    "runContext": {
        "urlPattern": "^https://(www\\.)?bbb\\.org/"
    },
    "prehideSelectors": ["iabbb-cookies-message"],
    "detectCmp": [
        {
            "exists": "iabbb-cookies-message section[aria-labelledby=\"cookiesMessage-heading\"]"
        }
    ],
    "detectPopup": [
        {
            "visible": "iabbb-cookies-message section[aria-labelledby=\"cookiesMessage-heading\"]"
        }
    ],
    "optIn": [
        {
            "waitForThenClick": "iabbb-cookies-message button[name=\"allow-all\"]"
        }
    ],
    "optOut": [
        {
            "hide": "iabbb-cookies-message"
        }
    ],
    "test": [
        {
            "waitForVisible": "iabbb-cookies-message section[aria-labelledby=\"cookiesMessage-heading\"]",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
