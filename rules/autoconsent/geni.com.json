{
    "name": "geni.com",
    "vendorUrl": "https://www.geni.com/",
    "cosmetic": true,
    "runContext": {
        "urlPattern": "^https://(www\\.)?geni\\.com/"
    },
    "prehideSelectors": [".modal-cookie"],
    "detectCmp": [
        {
            "exists": ".modal-cookie"
        }
    ],
    "detectPopup": [
        {
            "visible": ".modal-cookie"
        }
    ],
    "optIn": [
        {
            "waitForThenClick": ".modal-cookie #accept-all"
        }
    ],
    "optOut": [
        {
            "hide": ".modal-cookie"
        }
    ]
}
