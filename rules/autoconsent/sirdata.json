{
    "name": "sirdata",
    "_metadata": {
        "vendorUrl": "https://cache.consentframework.com/"
    },
    "prehideSelectors": ["#sd-cmp .sd-cmp-4oXwF", "#sd-cmp .sd-cmp-wBgKb"],
    "detectCmp": [
        {
            "any": [
                { "exists": "script[src*=\"cache.consentframework.com\"]" },
                { "exists": "script[src*=\"consentframework.com\"]" },
                { "exists": "#sd-cmp" }
            ]
        }
    ],
    "detectPopup": [
        {
            "any": [{ "visible": "#sd-cmp .sd-cmp-4oXwF" }, { "visible": "#sd-cmp .sd-cmp-wBgKb" }]
        }
    ],
    "optIn": [
        {
            "if": {
                "exists": "#sd-cmp .sd-cmp-mfn-G button"
            },
            "then": [
                {
                    "waitForThenClick": "#sd-cmp .sd-cmp-mfn-G button"
                },
                {
                    "wait": 300
                }
            ]
        },
        {
            "if": {
                "visible": "xpath///div[@id='sd-cmp']//button[.//span[contains(.,'Accept the sale')]]"
            },
            "then": [
                {
                    "waitForThenClick": "xpath///div[@id='sd-cmp']//button[.//span[contains(.,'Accept the sale')]]"
                }
            ],
            "else": [
                {
                    "if": {
                        "visible": "xpath///div[@id='sd-cmp']//button[contains(.,'Accept all')]"
                    },
                    "then": [
                        {
                            "waitForThenClick": "xpath///div[@id='sd-cmp']//button[contains(.,'Accept all')]"
                        }
                    ]
                }
            ]
        },
        {
            "eval": "EVAL_SIRDATA_OPTIN",
            "optional": true
        },
        {
            "eval": "EVAL_SIRDATA_UNBLOCK_SCROLL",
            "optional": true
        },
        {
            "addStyle": "overflow: auto !important",
            "selector": "html",
            "optional": true
        },
        {
            "addStyle": "overflow: auto !important",
            "selector": "body",
            "optional": true
        }
    ],
    "optOut": [
        {
            "if": {
                "exists": "#sd-cmp .sd-cmp-mfn-G button"
            },
            "then": [
                {
                    "waitForThenClick": "#sd-cmp .sd-cmp-mfn-G button"
                },
                {
                    "wait": 300
                }
            ]
        },
        {
            "eval": "EVAL_SIRDATA_OPTOUT"
        },
        {
            "eval": "EVAL_SIRDATA_UNBLOCK_SCROLL",
            "optional": true
        },
        {
            "addStyle": "overflow: auto !important",
            "selector": "html",
            "optional": true
        },
        {
            "addStyle": "overflow: auto !important",
            "selector": "body",
            "optional": true
        }
    ],
    "test": [
        {
            "any": [
                {
                    "eval": "EVAL_SIRDATA_USP_OPT_OUT_TEST"
                },
                {
                    "eval": "EVAL_SIRDATA_TEST"
                },
                {
                    "visible": "#sd-cmp .sd-cmp-wBgKb",
                    "negated": true
                }
            ]
        }
    ],
    "minimumRuleStepVersion": 2
}
