{
    "name": "aquasana.com",
    "minimumRuleStepVersion": 2,
    "prehideSelectors": ["#consent-tracking"],
    "detectCmp": [{ "exists": "#consent-tracking" }],
    "detectPopup": [{ "exists": "#consent-tracking" }],
    "optIn": [
        {
            "if": { "exists": "#consent-tracking .btn-all" },
            "then": [{ "click": "#consent-tracking .btn-all" }],
            "else": [{ "click": "#consent-tracking .affirm.btn" }]
        },
        { "waitForVisible": "#consent-tracking", "check": "none", "timeout": 3000, "optional": true },
        { "removeClass": "modal-open", "selector": "html", "optional": true },
        { "removeClass": "modal-open", "selector": "body", "optional": true },
        { "addStyle": "overflow: auto !important", "selector": "html", "optional": true },
        { "addStyle": "overflow: auto !important", "selector": "body", "optional": true }
    ],
    "optOut": [
        {
            "if": { "exists": "#consent-tracking .decline.btn" },
            "then": [{ "click": "#consent-tracking .decline.btn" }],
            "else": [
                {
                    "if": { "exists": "#consent-tracking .btn-necessary" },
                    "then": [{ "click": "#consent-tracking .btn-necessary" }],
                    "else": [{ "hide": "#consent-tracking" }]
                }
            ]
        },
        { "waitForVisible": "#consent-tracking", "check": "none", "timeout": 3000, "optional": true },
        { "removeClass": "modal-open", "selector": "html", "optional": true },
        { "removeClass": "modal-open", "selector": "body", "optional": true },
        { "addStyle": "overflow: auto !important", "selector": "html", "optional": true },
        { "addStyle": "overflow: auto !important", "selector": "body", "optional": true }
    ]
}
