{
    "name": "ourworldindata",
    "vendorUrl": "https://ourworldindata.org/",
    "runContext": {
        "urlPattern": "^https://ourworldindata\\.org/"
    },
    "prehideSelectors": [".cookie-manager"],
    "detectCmp": [
        {
            "exists": ".cookie-manager"
        }
    ],
    "detectPopup": [
        {
            "visible": ".cookie-manager .cookie-notice.open"
        }
    ],
    "optIn": [
        {
            "waitForThenClick": ".cookie-notice button.owid-btn--solid-dark-blue.cookie-notice__button"
        }
    ],
    "optOut": [
        {
            "waitForThenClick": ".cookie-notice button.owid-btn--outline-dark-blue.cookie-notice__button"
        }
    ]
}
