{
    "name": "alaskaair",
    "vendorUrl": "https://www.alaskaair.com/",
    "prehideSelectors": ["#cc-main"],
    "runContext": {
        "urlPattern": "^https?://(www\\.)?alaskaair\\.com/"
    },
    "_metadata": {
        "vendorUrl": "https://github.com/orestbida/cookieconsent"
    },
    "comment": "Tealium-loaded CookieConsent v3 (orestbida). Opt in/out use CookieConsent.acceptCategory — the bar can show one Dismiss button tied to data-role=all.",
    "detectCmp": [
        {
            "any": [
                {
                    "exists": "script[src*='tiqcdn.com/utag/alaska/']"
                },
                {
                    "exists": "#cc-main"
                }
            ]
        }
    ],
    "detectPopup": [{ "eval": "EVAL_ALASKAAIR_CC3_POPUP" }],
    "optIn": [{ "eval": "EVAL_ALASKAAIR_CC3_OPT_IN" }],
    "optOut": [
        { "eval": "EVAL_ALASKAAIR_CC3_OPT_OUT" },
        {
            "hide": "#cc-main",
            "optional": true
        },
        {
            "waitForVisible": "#cc-main",
            "check": "none",
            "timeout": 2000,
            "optional": true
        }
    ],
    "test": [{ "eval": "EVAL_ALASKAAIR_CC3_TEST" }]
}
