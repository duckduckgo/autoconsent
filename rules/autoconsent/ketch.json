{
    "name": "ketch",
    "vendorUrl": "https://www.ketch.com",
    "runContext": {
        "frame": false,
        "main": true
    },
    "intermediate": false,
    "prehideSelectors": ["#lanyard_root div[role='dialog']", "#ketch-banner", "#ketch-modal"],
    "detectCmp": [
        {
            "any": [
                { "exists": "#lanyard_root div[role='dialog']" },
                { "exists": "#ketch-banner" },
                { "exists": "#ketch-modal" },
                { "exists": "#lanyard_root [class*='ketch-fixed']" }
            ]
        }
    ],
    "detectPopup": [
        {
            "any": [{ "visible": "#lanyard_root div[role='dialog']" }, { "visible": "#ketch-banner" }, { "visible": "#ketch-modal" }]
        }
    ],
    "optIn": [
        {
            "if": {
                "exists": "#lanyard_root button[class='confirmButton']"
            },
            "then": [
                { "waitForThenClick": "#lanyard_root div[class*=buttons] > :nth-child(2)" },
                { "click": "#lanyard_root button[class='confirmButton']" }
            ],
            "else": [
                {
                    "waitForThenClick": "#ketch-banner-button-primary, #lanyard_root div[class*=buttons] > :nth-child(2)"
                }
            ]
        }
    ],
    "optOut": [
        {
            "comment": "Banner phase: nested if/else so exactly one action runs. Ketch's primary/secondary/tertiary ids reflect visual hierarchy, not role, so a successful aria-label reject must not fall through to tertiary (which is 'Cookie Settings' on some layouts, e.g. PBS).",
            "if": {
                "exists": "#lanyard_root button[aria-label^='Reject' i], #ketch-banner button[aria-label^='Reject' i]"
            },
            "then": [
                {
                    "comment": "Direct reject-style button, matched by aria-label prefix ('Reject All', 'Reject Optional Cookies', etc.).",
                    "waitForThenClick": "#lanyard_root button[aria-label^='Reject' i], #ketch-banner button[aria-label^='Reject' i]"
                },
                {
                    "comment": "Some variants show the preferences modal directly and treat Reject All as 'toggle all off'. If the modal is still visible, submit it.",
                    "if": {
                        "visible": "#lanyard_root [aria-describedby=preference-description], #lanyard_root [aria-describedby=modal-description], #ketch-modal, #ketch-purposes-modal, #ketch-preferences"
                    },
                    "then": [
                        {
                            "click": "#lanyard_root button[class*=confirmButton], #lanyard_root div[class*=actions_] > button:nth-child(1), #lanyard_root button[class*=actionButton], #ketch-modal button[aria-label='Confirm'], #ketch-purposes-modal button[aria-label='Confirm'], #ketch-modal button[aria-label='Save Settings'], #ketch-purposes-modal button[aria-label='Save Settings']"
                        }
                    ]
                }
            ],
            "else": [
                {
                    "comment": "Legacy fallback: reject button without matching aria-label, exposed as #ketch-banner-button-tertiary.",
                    "if": {
                        "exists": "#ketch-banner-button-tertiary"
                    },
                    "then": [{ "waitForThenClick": "#ketch-banner-button-tertiary" }],
                    "else": [
                        {
                            "comment": "Older banner (aria-describedby=banner-description): click secondary to open settings, or dismiss single-button disclosure. Preferences modal handled by the trailing step.",
                            "if": {
                                "exists": "#lanyard_root [aria-describedby=banner-description]"
                            },
                            "then": [
                                {
                                    "if": {
                                        "exists": "#lanyard_root div[class*=buttons] > button[class*=secondaryButton], #lanyard_root button[class*=buttons-secondary], #ketch-banner-button-secondary"
                                    },
                                    "then": [
                                        {
                                            "waitForThenClick": "#lanyard_root div[class*=buttons] > button[class*=secondaryButton], #lanyard_root button[class*=buttons-secondary], #ketch-banner-button-secondary",
                                            "comment": "settings or reject button"
                                        }
                                    ],
                                    "else": [
                                        {
                                            "if": {
                                                "exists": "#lanyard_root [id^='ketch-banner-buttons-container'] > button:only-child"
                                            },
                                            "then": [
                                                {
                                                    "click": "#lanyard_root [id^='ketch-banner-buttons-container'] > button:only-child",
                                                    "comment": "Disclosure-only banner (US/CCPA acknowledge): consent is set by jurisdiction defaults."
                                                }
                                            ]
                                        }
                                    ]
                                }
                            ]
                        }
                    ]
                }
            ]
        },
        {
            "waitFor": "#lanyard_root [aria-describedby=preference-description],#lanyard_root [aria-describedby=modal-description], #ketch-preferences, #ketch-purposes-modal",
            "timeout": 1000,
            "optional": true
        },
        {
            "comment": "Preferences modal open (typically after opening settings from the banner): prefer Reject All, else uncheck every enabled toggle; then confirm/save.",
            "if": {
                "exists": "#lanyard_root [aria-describedby=preference-description],#lanyard_root [aria-describedby=modal-description], #ketch-preferences, #ketch-purposes-modal"
            },
            "then": [
                {
                    "if": {
                        "exists": "#lanyard_root button[class*=rejectButton], #lanyard_root button[class*=rejectAllButton], #ketch-modal button[aria-label='Reject All'], #ketch-purposes-modal button[aria-label='Reject All']"
                    },
                    "then": [
                        {
                            "waitForThenClick": "#lanyard_root button[class*=rejectButton], #lanyard_root button[class*=rejectAllButton], #ketch-modal button[aria-label='Reject All'], #ketch-purposes-modal button[aria-label='Reject All']"
                        }
                    ],
                    "else": [
                        {
                            "comment": "No 'Reject All' in this jurisdiction (e.g. US/CCPA per-purpose toggles): flip off each enabled switch.",
                            "click": "#lanyard_root input[type=checkbox][role=switch][aria-checked=true]:not(:disabled)",
                            "all": true,
                            "optional": true
                        }
                    ]
                },
                {
                    "click": "#lanyard_root button[class*=confirmButton], #lanyard_root div[class*=actions_] > button:nth-child(1), #lanyard_root button[class*=actionButton], #ketch-modal button[aria-label='Confirm'], #ketch-purposes-modal button[aria-label='Confirm'], #ketch-modal button[aria-label='Save Settings'], #ketch-purposes-modal button[aria-label='Save Settings']"
                }
            ]
        }
    ],
    "test": [{ "cookieContains": "_ketch_consent_v1_" }]
}
