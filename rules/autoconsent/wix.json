{
    "name": "wix",
    "vendorUrl": "https://www.wix.com/",
    "cosmetic": false,
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "[data-comp-type=cookie-banner-root-wix],[data-comp-type=cookie-banner-root-uou],[data-hook=ccsu-banner-wrapper],[data-hook=consent-banner-root]"
        }
    ],
    "detectPopup": [
        {
            "visible": "[data-comp-type=cookie-banner-root-wix],[data-comp-type=cookie-banner-root-uou],[data-hook=ccsu-banner-wrapper],[data-hook=consent-banner-root]"
        }
    ],
    "optIn": [
        {
            "if": { "exists": "[data-hook=ccsu-banner-accept]" },
            "then": [{ "click": "[data-hook=ccsu-banner-accept]" }],
            "else": [
                {
                    "if": { "exists": "[data-hook=consent-banner-apply-button]" },
                    "then": [{ "click": "[data-hook=consent-banner-apply-button]" }],
                    "else": [{ "click": "[data-hook=ccsu-banner-decline]" }]
                }
            ]
        }
    ],
    "optOut": [
        {
            "if": { "exists": "[data-hook=ccsu-banner-decline-all]" },
            "then": [{ "click": "[data-hook=ccsu-banner-decline-all]" }],
            "else": [
                {
                    "if": { "exists": "[data-hook=consent-banner-settings-button]" },
                    "then": [
                        { "waitForThenClick": "[data-hook=consent-banner-settings-button]" },
                        { "waitForVisible": "[data-hook=consent-banner-settings-save-button]" },
                        { "wait": 500 },
                        { "click": "[data-hook=consent-banner-settings-save-button]" }
                    ],
                    "else": [{ "hide": "[data-hook=ccsu-banner-wrapper]" }]
                }
            ]
        }
    ]
}
