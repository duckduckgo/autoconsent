{
    "name": "cookieconsent2",
    "vendorUrl": "https://www.github.com/orestbida/cookieconsent",
    "comment": "supports v2.x.x of the library",
    "prehideSelectors": ["#cc--main"],
    "detectCmp": [
        {
            "exists": "#cc--main"
        }
    ],
    "detectPopup": [
        {
            "visible": "#cm"
        },
        {
            "exists": "#s-all-bn"
        }
    ],
    "optIn": [
        {
            "waitForThenClick": "#s-all-bn"
        }
    ],
    "optOut": [
        {
            "if": { "exists": "#s-rall-bn" },
            "then": [{ "waitForThenClick": "#s-rall-bn" }],
            "else": [{ "waitForThenClick": "#c-s-bn" }, { "waitForThenClick": "#s-sv-bn" }]
        }
    ],
    "test": [
        {
            "cookieContains": "cc_cookie="
        }
    ]
}
