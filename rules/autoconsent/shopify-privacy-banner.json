{
    "name": "shopify-privacy-banner",
    "prehideSelectors": ["#shopify-pc__banner"],
    "detectCmp": [{ "exists": "#shopify-pc__banner" }],
    "detectPopup": [{ "visible": "#shopify-pc__banner", "check": "any" }],
    "optIn": [{ "waitForThenClick": "#shopify-pc__banner__btn-accept" }],
    "optOut": [{ "waitForThenClick": "#shopify-pc__banner__btn-decline" }],
    "test": [
        { "waitForVisible": "#shopify-pc__banner", "timeout": 2000, "check": "none" },
        { "wait": 2000 },
        {
            "any": [
                { "eval": "EVAL_SHOPIFY_PRIVACY_BANNER_TEST" },
                { "waitForVisible": "#shopify-pc__banner", "timeout": 500, "check": "none" }
            ]
        }
    ]
}
