{
    "name": "ring.com",
    "_metadata": {
        "vendorUrl": "https://ring.com/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https://([a-z0-9-]+\\.)*ring\\.com/"
    },
    "prehideSelectors": [".consent-banner"],
    "detectCmp": [{ "exists": "script#consent-script[src*=\"consent-manager\"]" }],
    "detectPopup": [{ "visible": "body.has-banner .consent-banner" }],
    "optIn": [{ "waitForThenClick": "button.consent--accept", "timeout": 10000 }],
    "optOut": [
        {
            "if": { "exists": "button.consent--reject" },
            "then": [{ "waitForThenClick": "button.consent--reject", "timeout": 10000 }],
            "else": [{ "eval": "EVAL_RING_CONSENT_OPT_OUT" }]
        }
    ],
    "test": [{ "eval": "EVAL_RING_CONSENT_TEST" }]
}
