{
    "name": "ring.com",
    "_metadata": {
        "vendorUrl": "https://ring.com/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https://([a-z0-9-]+\\.)*ring\\.com/"
    },
    "prehideSelectors": [],
    "detectCmp": [{ "exists": "script#consent-script[src*=\"consent-manager\"]" }],
    "detectPopup": [{ "visible": ".consent-banner" }],
    "optIn": [{ "waitForThenClick": "button.consent--accept", "timeout": 10000 }],
    "optOut": [
        {
            "if": { "visible": "button.consent--reject" },
            "then": [{ "waitForThenClick": "button.consent--reject", "timeout": 10000 }],
            "else": [
                { "waitForThenClick": "button.consent--manage", "timeout": 10000 },
                { "waitForThenClick": "button.consent-save", "timeout": 10000 }
            ]
        }
    ],
    "test": [{ "cookieContains": "privacy-banner-clicked=true" }]
}
