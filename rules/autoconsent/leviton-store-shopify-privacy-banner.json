{
    "name": "leviton-store-shopify-privacy-banner",
    "_metadata": {
        "vendorUrl": "https://store.leviton.com/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://store\\.leviton\\.com/"
    },
    "prehideSelectors": ["#shopify-pc__banner"],
    "detectCmp": [{ "exists": "#shopify-pc__banner" }],
    "detectPopup": [
        {
            "visible": "#shopify-pc__banner",
            "check": "any"
        }
    ],
    "optIn": [{ "waitForThenClick": "#shopify-pc__banner__btn-accept" }],
    "optOut": [{ "wait": 500 }, { "waitForThenClick": "#shopify-pc__banner__btn-decline" }],
    "test": [
        {
            "waitForVisible": "#shopify-pc__banner",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
