{
    "name": "americangreetings-tealium",
    "cosmetic": true,
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?americangreetings\\.com/"
    },
    "_metadata": {
        "vendorUrl": "https://www.americangreetings.com/"
    },
    "prehideSelectors": ["#__tealiumGDPRecModal #privacy_manager.privacy_prompt"],
    "detectCmp": [{ "exists": "#__tealiumGDPRecModal #privacy_manager.privacy_prompt" }],
    "detectPopup": [{ "visible": "#__tealiumGDPRecModal #privacy_manager.privacy_prompt" }],
    "optOut": [{ "hide": "#__tealiumGDPRecModal" }],
    "optIn": [{ "waitForThenClick": "#accept_cookies" }],
    "test": [{ "waitForVisible": "#__tealiumGDPRecModal", "timeout": 1000, "check": "none" }]
}
