{
    "name": "transcend",
    "_metadata": {
        "vendorUrl": "https://transcend.io/"
    },
    "cosmetic": true,
    "minimumRuleStepVersion": 2,
    "prehideSelectors": ["#transcend-consent-manager"],
    "detectCmp": [{ "exists": "#transcend-consent-manager" }],
    "detectPopup": [{ "visible": ["#transcend-consent-manager", "#consentManagerMainDialog"] }],
    "optIn": [
        {
            "waitForThenClick": ["#transcend-consent-manager", "#consentManagerMainDialog button.button"],
            "timeout": 20000
        }
    ],
    "optOut": [
        {
            "waitForThenClick": ["#transcend-consent-manager", "#consentManagerMainDialog button.button"],
            "timeout": 20000
        },
        {
            "setStyle": "display: none !important; z-index: -1 !important; pointer-events: none !important;",
            "selector": "#transcend-consent-manager",
            "optional": true
        }
    ],
    "test": [
        {
            "visible": ["#transcend-consent-manager", "#consentManagerMainDialog"],
            "check": "none"
        }
    ]
}
