{
    "name": "transcend",
    "vendorUrl": "https://transcend.io",
    "cosmetic": true,
    "prehideSelectors": ["#transcend-consent-manager", "#transcend-consent-manager-tcf-ui"],
    "detectCmp": [
        {
            "exists": "#transcend-consent-manager, #transcend-consent-manager-tcf-ui"
        }
    ],
    "detectPopup": [
        {
            "visible": "#transcend-consent-manager, #transcend-consent-manager-tcf-ui"
        },
        {
            "eval": "EVAL_TRANSCEND_POPUP_SHOWN"
        }
    ],
    "optIn": [
        {
            "waitForThenClick": ["#transcend-consent-manager", "#consentManagerMainDialog .inner-container button"]
        }
    ],
    "optOut": [
        {
            "hide": "#transcend-consent-manager, #transcend-consent-manager-tcf-ui"
        }
    ]
}
