{
    "name": "copilot-microsoft",
    "_metadata": {
        "vendorUrl": "https://copilot.microsoft.com"
    },
    "cosmetic": false,
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https://copilot\\.microsoft\\.com/"
    },
    "prehideSelectors": ["#cookie-banner"],
    "detectCmp": [{ "exists": "#cookie-banner" }],
    "detectPopup": [{ "visible": "#cookie-banner" }],
    "optIn": [{ "waitForThenClick": "[data-testid='cookie-banner-accept-button']" }],
    "optOut": [{ "waitForThenClick": "[data-testid='cookie-banner-reject-button']" }],
    "test": [{ "eval": "EVAL_MICROSOFT_2" }]
}
