{
    "name": "cookieconsent3",
    "vendorUrl": "https://www.github.com/orestbida/cookieconsent",
    "comment": "supports v3.x.x of the library",
    "prehideSelectors": ["#cc-main"],
    "detectCmp": [
        {
            "exists": "#cc-main"
        }
    ],
    "detectPopup": [
        {
            "visible": "#cc-main .cm-wrapper, #cc-main .pm-wrapper",
            "check": "any"
        }
    ],
    "optIn": [
        {
            "if": { "exists": "#cc-main .cm-wrapper .cm__btn[data-role=all]" },
            "then": [{ "waitForThenClick": "#cc-main .cm-wrapper .cm__btn[data-role=all]" }],
            "else": [
                { "click": "#cc-main .cm-wrapper .cm__btn[data-role=show]", "optional": true },
                { "waitForThenClick": "#cc-main .pm-wrapper .pm__btn[data-role=all]" }
            ]
        }
    ],
    "optOut": [
        {
            "if": { "exists": "#cc-main .cm-wrapper .cm__btn[data-role=necessary]" },
            "then": [{ "waitForThenClick": "#cc-main .cm-wrapper .cm__btn[data-role=necessary]" }],
            "else": [
                { "click": "#cc-main .cm-wrapper .cm__btn[data-role=show]", "optional": true },
                { "waitForThenClick": "#cc-main .pm-wrapper .pm__btn[data-role=necessary]" }
            ]
        }
    ],
    "test": [
        {
            "cookieContains": "cc_cookie="
        }
    ]
}
