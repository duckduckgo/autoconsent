{
    "name": "figma-consent",
    "_metadata": {
        "vendorUrl": "https://consent.figma.com/"
    },
    "prehideSelectors": ["iframe#fig-consent-iframe", "iframe[src*=\"consent.figma.com\"]"],
    "runContext": {
        "main": false,
        "frame": true,
        "urlPattern": "^https://consent\\.figma\\.com/"
    },
    "detectCmp": [{ "exists": "[role=\"alertdialog\"][aria-label=\"Cookie Consent\"]" }],
    "detectPopup": [{ "visible": "[role=\"alertdialog\"][aria-label=\"Cookie Consent\"]" }],
    "optIn": [
        {
            "if": { "exists": "xpath///button[normalize-space(.)=\"Allow all cookies\"]" },
            "then": [{ "waitForThenClick": "xpath///button[normalize-space(.)=\"Allow all cookies\"]" }],
            "else": [{ "waitForThenClick": "button[aria-label=\"dismiss\"]" }]
        }
    ],
    "optOut": [
        {
            "if": { "exists": "xpath///button[normalize-space(.)=\"Do not allow cookies\"]" },
            "then": [{ "waitForThenClick": "xpath///button[normalize-space(.)=\"Do not allow cookies\"]" }],
            "else": [{ "waitForThenClick": "xpath///button[normalize-space(.)=\"Opt-Out\"]" }]
        }
    ],
    "test": [{ "cookieContains": "f-pref=%7B%22t%22%3A%22" }]
}
