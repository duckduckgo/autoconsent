{
    "name": "bbb.org",
    "cosmetic": false,
    "prehideSelectors": ["iabbb-cookies-message"],
    "detectCmp": [{ "exists": "iabbb-cookies-message" }],
    "detectPopup": [{ "visible": "iabbb-cookies-message .bds-button[name='allow-all']" }],
    "optIn": [{ "click": "iabbb-cookies-message .bds-button[name='allow-all']" }],
    "optOut": [
        { "waitForVisible": "iabbb-cookies-message button.bds-button-unstyled" },
        { "wait": 500 },
        { "click": "iabbb-cookies-message button.bds-button-unstyled" },
        { "waitFor": "iabbb-cookies-message dialog[open]" },
        {
            "click": "iabbb-cookies-message dialog fieldset input[type=radio][value=false]:not(:checked)",
            "all": true,
            "optional": true
        },
        {
            "click": "iabbb-cookies-message dialog button.bds-button"
        },
        {
            "waitForThenClick": "iabbb-cookies-message button.bds-button:not([name])"
        }
    ]
}
