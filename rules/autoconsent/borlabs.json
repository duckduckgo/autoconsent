{
    "name": "borlabs",
    "prehideSelectors": ["#BorlabsCookieBox"],
    "detectCmp": [
        {
            "exists": "._brlbs-block-content,.brlbs-cmpnt-dialog"
        }
    ],
    "detectPopup": [
        {
            "visible": "._brlbs-bar-wrap,._brlbs-box-wrap,.brlbs-cmpnt-dialog"
        }
    ],
    "optIn": [
        {
            "waitForThenClick": "a[data-cookie-accept-all],.brlbs-btn-accept-all"
        }
    ],
    "optOut": [
        {
            "if": { "exists": ".brlbs-btn-accept-only-essential,a[data-cookie-refuse]" },
            "then": [{ "click": ".brlbs-btn-accept-only-essential,a[data-cookie-refuse]" }],
            "else": [
                {
                    "waitForThenClick": "a[data-cookie-individual],#CookieBoxPreferencesButton,.brlbs-cmpnt-btn-preferences"
                },
                {
                    "waitForVisible": ".cookie-preference,.brlbs-cmpnt-dialog-details"
                },
                {
                    "click": "input[data-borlabs-cookie-checkbox]:checked,input.brlbs-cmpnt-checkbox:checked:not(:disabled)",
                    "all": true,
                    "optional": true
                },
                {
                    "waitForThenClick": "#CookiePrefSave,#CookieBoxSaveButton,.brlbs-btn-save"
                },
                {
                    "wait": 500
                }
            ]
        }
    ],
    "test": [
        {
            "eval": "EVAL_BORLABS_0"
        }
    ]
}
