{
    "name": "bandcamp.com",
    "runContext": {
        "urlPattern": "^https://(www\\.)?bandcamp\\.com"
    },
    "prehideSelectors": [".dialog-container"],
    "detectCmp": [
        {
            "exists": ".dialog-container .cookie-dialog-initial"
        }
    ],
    "detectPopup": [
        {
            "visible": ".cookie-dialog-initial"
        }
    ],
    "optIn": [
        {
            "waitForThenClick": ".cookie-dialog-initial button.g-button[type=\"submit\"]"
        }
    ],
    "optOut": [
        {
            "waitForThenClick": ".cookie-dialog-initial button.g-button.outline"
        }
    ]
}
