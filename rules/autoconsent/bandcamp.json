{
    "name": "bandcamp.com",
    "runContext": {
        "urlPattern": "^https://([a-z0-9-]+\\.)?bandcamp\\.com"
    },
    "detectCmp": [
        {
            "exists": "body.enable-cookie-control"
        }
    ],
    "detectPopup": [
        {
            "any": [{ "visible": ".cookie-dialog-initial" }, { "visible": ["page-footer", ".cookie-dialog-initial"] }]
        }
    ],
    "optIn": [
        {
            "if": { "exists": "page-footer" },
            "then": [
                {
                    "waitForThenClick": ["page-footer", ".cookie-dialog-initial button.g-button[type=\"submit\"]"]
                }
            ],
            "else": [
                {
                    "waitForThenClick": ".cookie-dialog-initial button.g-button[type=\"submit\"]"
                }
            ]
        }
    ],
    "optOut": [
        {
            "if": { "exists": "page-footer" },
            "then": [
                {
                    "waitForThenClick": ["page-footer", ".cookie-dialog-initial button.g-button.outline"]
                }
            ],
            "else": [
                {
                    "waitForThenClick": ".cookie-dialog-initial button.g-button.outline"
                }
            ]
        }
    ],
    "test": [
        {
            "cookieContains": "cookie_preferences=%7B%22allow%22%3A%5B%5D"
        }
    ]
}
