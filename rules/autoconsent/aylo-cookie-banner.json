{
    "name": "aylo-cookie-banner",
    "_metadata": {
        "vendorUrl": "https://www.redtube.com/"
    },
    "prehideSelectors": ["#cookie_consent_wrapper, #cookie_consent_min_wrapper, #manage_cookie_consent_modal"],
    "detectCmp": [
        {
            "exists": "#cookie_consent_wrapper:not(.hideConsent) #consent_manage_btn"
        },
        {
            "exists": "#manage_cookie_consent_modal #modal_consent_accept_essential"
        }
    ],
    "detectPopup": [
        {
            "visible": "#cookie_consent_wrapper:not(.hideConsent)"
        }
    ],
    "optIn": [
        {
            "waitForThenClick": "#manage_cookie_consent_modal #modal_consent_accept_all"
        }
    ],
    "optOut": [
        {
            "waitForThenClick": "#manage_cookie_consent_modal #modal_consent_accept_essential"
        },
        {
            "waitForThenClick": "#cookie_consent_min_wrapper #close_minimized_banner",
            "comment": "dismiss the 'Some features may not be available...' minimized banner that appears after opting out",
            "optional": true
        }
    ],
    "test": [
        {
            "cookieContains": "cookieConsent=1"
        }
    ]
}
