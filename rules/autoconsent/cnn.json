{
    "name": "cnn",
    "vendorUrl": "https://www.cnn.com/",
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https://(www\\.)?cnn\\.com/"
    },
    "prehideSelectors": [
        "body > div[aria-hidden=\"true\"]:has(> div[role=\"dialog\"][aria-modal=\"true\"] > a[role=\"button\"][href=\"#\"])"
    ],
    "detectCmp": [
        { "exists": "iframe[name=\"_usrConWBD\"]" },
        {
            "exists": "xpath///body/div[@aria-hidden=\"true\"][div[@role=\"dialog\" and @aria-modal=\"true\"]/h2[normalize-space()=\"Legal Terms and Privacy\"]]"
        }
    ],
    "detectPopup": [
        {
            "visible": "xpath///body/div[@aria-hidden=\"true\"][div[@role=\"dialog\" and @aria-modal=\"true\"]/h2[normalize-space()=\"Legal Terms and Privacy\"]]"
        }
    ],
    "optIn": [
        {
            "waitForThenClick": "xpath///body/div[@aria-hidden=\"true\"]/div[@role=\"dialog\" and @aria-modal=\"true\"]/a[@role=\"button\" and normalize-space()=\"Agree\"]"
        }
    ],
    "optOut": [
        {
            "waitForThenClick": "xpath///body/div[@aria-hidden=\"true\"]/div[@role=\"dialog\" and @aria-modal=\"true\"]/a[@role=\"button\" and normalize-space()=\"Agree\"]"
        }
    ]
}
