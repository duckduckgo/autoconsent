{
    "name": "cookiesjsr",
    "prehideSelectors": ["#cookiesjsr"],
    "detectCmp": [{ "exists": "#cookiesjsr" }],
    "detectPopup": [{ "visible": "#cookiesjsr .cookiesjsr-banner" }, { "cookieContains": "cookiesjsr=", "negated": true }],
    "optIn": [{ "waitForThenClick": "#cookiesjsr button.allowAll" }],
    "optOut": [
        {
            "if": { "exists": "#cookiesjsr button.denyAll" },
            "then": [{ "waitForThenClick": "#cookiesjsr button.denyAll" }],
            "else": [{ "hide": "#cookiesjsr" }]
        }
    ],
    "test": [{ "cookieContains": "cookiesjsr=" }]
}
