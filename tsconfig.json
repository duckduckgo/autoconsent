{
    "compilerOptions": {
        "target": "es2021",
        "allowJs": true,
        "checkJs": true,
        "resolveJsonModule": true,
        "moduleResolution": "NodeNext",
        "noImplicitAny": true,
        "allowSyntheticDefaultImports": true,
        "strict": true,
        "module": "NodeNext",
        "types": ["node", "chrome", "mocha", "sinon", "chai"],
        "skipLibCheck": true
    },
    "exclude": ["node_modules/*", "dist/*"]
}
